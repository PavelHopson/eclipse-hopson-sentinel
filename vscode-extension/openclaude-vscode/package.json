{
  "name": "eclipse-hopson-sentinel-vscode",
  "displayName": "Eclipse Hopson Sentinel",
  "description": "VS Code extension for Eclipse Hopson Sentinel with control center and terminal launch integration.",
  "version": "0.1.1",
  "publisher": "devnull-bootloader",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sentinel.start",
    "onCommand:sentinel.openDocs",
    "onCommand:sentinel.openControlCenter",
    "onView:sentinel.controlCenter"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sentinel.start",
        "title": "Sentinel: Launch in Terminal",
        "category": "Sentinel"
      },
      {
        "command": "sentinel.openDocs",
        "title": "Sentinel: Open Repository",
        "category": "Sentinel"
      },
      {
        "command": "sentinel.openControlCenter",
        "title": "Sentinel: Open Control Center",
        "category": "Sentinel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sentinel",
          "title": "Sentinel",
          "icon": "media/openclaude.svg"
        }
      ]
    },
    "views": {
      "sentinel": [
        {
          "id": "sentinel.controlCenter",
          "name": "Control Center",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Sentinel",
      "properties": {
        "sentinel.launchCommand": {
          "type": "string",
          "default": "sentinel",
          "description": "Command executed in the integrated terminal."
        },
        "sentinel.terminalName": {
          "type": "string",
          "default": "Sentinel",
          "description": "Integrated terminal tab name for Sentinel sessions."
        },
        "sentinel.useOpenAIShim": {
          "type": "boolean",
          "default": false,
          "description": "Optionally sets CLAUDE_CODE_USE_OPENAI=1 for launched terminals."
        }
      }
    },
    "themes": [
      {
        "label": "Sentinel Terminal Black",
        "uiTheme": "vs-dark",
        "path": "./themes/OpenClaude-Terminal-Black.json"
      }
    ]
  },
  "scripts": {
    "lint": "node --check ./src/extension.js",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "keywords": [
    "sentinel",
    "eclipse-hopson",
    "terminal",
    "theme",
    "cli",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PavelHopson/eclipse-hopson-sentinel"
  },
  "license": "MIT"
}
