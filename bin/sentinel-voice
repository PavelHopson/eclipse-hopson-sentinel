#!/usr/bin/env node

import { createInterface } from 'node:readline/promises'
import { stdin as input, stdout as output } from 'node:process'
import { spawn } from 'node:child_process'
import { dirname, resolve } from 'node:path'
import { fileURLToPath } from 'node:url'

function parseArgs(argv) {
  const config = {
    url: process.env.SENTINEL_BRIDGE_URL || 'http://127.0.0.1:8765',
    token: process.env.SENTINEL_BRIDGE_TOKEN || '',
    cwd: process.cwd(),
    speak: process.env.SENTINEL_VOICE_SPEAK === '1',
    voice: process.env.SENTINEL_TTS_VOICE || '',
    rate: Number(process.env.SENTINEL_TTS_RATE || '0'),
    listVoices: false,
    stt: process.env.SENTINEL_VOICE_STT === '1',
    sttTimeoutSeconds: Number(process.env.SENTINEL_STT_TIMEOUT || '8'),
  }

  for (let index = 0; index < argv.length; index += 1) {
    const part = argv[index]
    const next = argv[index + 1]

    if (part === '--url' && next) {
      config.url = next.replace(/\/$/, '')
      index += 1
      continue
    }

    if (part === '--token' && next) {
      config.token = next
      index += 1
      continue
    }

    if (part === '--cwd' && next) {
      config.cwd = next
      index += 1
      continue
    }

    if (part === '--speak') {
      config.speak = true
      continue
    }

    if (part === '--voice' && next) {
      config.voice = next
      index += 1
      continue
    }

    if (part === '--rate' && next) {
      const parsed = Number(next)
      if (!Number.isNaN(parsed)) {
        config.rate = parsed
      }
      index += 1
      continue
    }

    if (part === '--list-voices') {
      config.listVoices = true
      continue
    }

    if (part === '--stt') {
      config.stt = true
      continue
    }

    if (part === '--stt-timeout' && next) {
      const parsed = Number(next)
      if (!Number.isNaN(parsed) && parsed > 0) {
        config.sttTimeoutSeconds = parsed
      }
      index += 1
    }
  }

  return config
}

function getTtsScriptPath() {
  const currentDir = dirname(fileURLToPath(import.meta.url))
  return resolve(currentDir, '..', 'scripts', 'sentinel-tts.ps1')
}

function getSttScriptPath() {
  const currentDir = dirname(fileURLToPath(import.meta.url))
  return resolve(currentDir, '..', 'scripts', 'sentinel-stt.ps1')
}

async function createSession(config) {
  const response = await fetch(`${config.url}/v1/sessions`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      ...(config.token ? { Authorization: `Bearer ${config.token}` } : {}),
    },
    body: JSON.stringify({
      cwd: config.cwd,
    }),
  })

  const payload = await response.json()

  if (!response.ok) {
    const error = payload?.error || `HTTP ${response.status}`
    throw new Error(String(error))
  }

  return payload.session
}

async function askSession(config, sessionId, prompt) {
  const response = await fetch(`${config.url}/v1/sessions/${sessionId}/ask`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      ...(config.token ? { Authorization: `Bearer ${config.token}` } : {}),
    },
    body: JSON.stringify({
      prompt,
      cwd: config.cwd,
    }),
  })

  const payload = await response.json()

  if (!response.ok) {
    const error = payload?.error || `HTTP ${response.status}`
    throw new Error(String(error))
  }

  return payload
}

function formatResponse(payload) {
  if (typeof payload?.response?.reply === 'string' && payload.response.reply.trim()) {
    return payload.response.reply.trim()
  }

  if (Array.isArray(payload?.response?.errors) && payload.response.errors.length > 0) {
    return `[errors]\n${payload.response.errors.join('\n')}`
  }

  if (typeof payload?.stdout === 'string' && payload.stdout.trim()) {
    return payload.stdout.trim()
  }

  if (typeof payload?.stderr === 'string' && payload.stderr.trim()) {
    return `[stderr]\n${payload.stderr.trim()}`
  }

  return '[empty response]'
}

async function speakText(config, text) {
  if (!config.speak || !text.trim()) {
    return
  }

  const scriptPath = getTtsScriptPath()

  await new Promise((resolvePromise, rejectPromise) => {
    const args = [
      '-ExecutionPolicy',
      'Bypass',
      '-File',
      scriptPath,
      '-Text',
      text,
      '-Rate',
      String(config.rate),
    ]

    if (config.voice) {
      args.push('-Voice', config.voice)
    }

    const child = spawn('powershell', args, {
      stdio: 'ignore',
      windowsHide: true,
    })

    child.on('error', rejectPromise)
    child.on('close', code => {
      if (code === 0) {
        resolvePromise()
        return
      }

      rejectPromise(new Error(`TTS exited with code ${code}`))
    })
  })
}

async function listVoices() {
  const command =
    "$voice = New-Object -ComObject SAPI.SpVoice; $voice.GetVoices() | ForEach-Object { $_.GetDescription() }"

  await new Promise((resolvePromise, rejectPromise) => {
    const child = spawn(
      'powershell',
      ['-ExecutionPolicy', 'Bypass', '-Command', command],
      {
        stdio: 'inherit',
        windowsHide: true,
      },
    )

    child.on('error', rejectPromise)
    child.on('close', code => {
      if (code === 0) {
        resolvePromise()
        return
      }

      rejectPromise(new Error(`Voice listing exited with code ${code}`))
    })
  })
}

async function listenOnce(config) {
  const scriptPath = getSttScriptPath()

  return await new Promise((resolvePromise, rejectPromise) => {
    const child = spawn(
      'powershell',
      [
        '-ExecutionPolicy',
        'Bypass',
        '-File',
        scriptPath,
        '-TimeoutSeconds',
        String(config.sttTimeoutSeconds),
      ],
      {
        windowsHide: true,
      },
    )

    let stdout = ''
    let stderr = ''

    child.stdout.on('data', chunk => {
      stdout += chunk.toString()
    })

    child.stderr.on('data', chunk => {
      stderr += chunk.toString()
    })

    child.on('error', rejectPromise)
    child.on('close', code => {
      const raw = stdout.trim()

      if (raw) {
        try {
          const payload = JSON.parse(raw)
          if (payload?.ok && typeof payload.text === 'string') {
            resolvePromise(payload.text.trim())
            return
          }

          rejectPromise(new Error(payload?.error || 'Speech recognition failed'))
          return
        } catch {
          rejectPromise(new Error(raw))
          return
        }
      }

      rejectPromise(
        new Error(stderr.trim() || `Speech recognition exited with code ${code}`),
      )
    })
  })
}

async function main() {
  const config = parseArgs(process.argv.slice(2))

  if (config.listVoices) {
    await listVoices()
    return
  }

  const rl = createInterface({ input, output })
  const session = await createSession(config)

  output.write('Eclipse Hopson Sentinel Voice MVP\n')
  output.write(`Bridge: ${config.url}\n`)
  output.write(`Workspace: ${config.cwd}\n`)
  output.write(`Bridge session: ${session.id}\n`)
  output.write(`Speech output: ${config.speak ? 'enabled' : 'disabled'}\n`)
  output.write(`Speech input: ${config.stt ? 'enabled' : 'disabled'}\n`)
  output.write("Type your request and press Enter. Type 'exit' to quit.\n\n")

  try {
    while (true) {
      let prompt = (await rl.question('sentinel-voice> ')).trim()

      if (!prompt) {
        continue
      }

      if (prompt.toLowerCase() === 'exit') {
        break
      }

      if (prompt.toLowerCase() === '/listen') {
        if (!config.stt) {
          output.write(
            "\n[voice] STT is disabled. Restart with --stt to enable microphone capture.\n\n",
          )
          continue
        }

        output.write(
          `\n[voice] Listening for up to ${config.sttTimeoutSeconds} seconds...\n`,
        )

        try {
          prompt = await listenOnce(config)
          output.write(`[voice] Heard: ${prompt}\n\n`)
        } catch (error) {
          const message =
            error instanceof Error ? error.message : 'Speech recognition failed'
          output.write(`\n[voice input error] ${message}\n\n`)
          continue
        }
      }

      try {
        const payload = await askSession(config, session.id, prompt)
        const text = formatResponse(payload)
        output.write(`\n${text}\n\n`)
        await speakText(config, text)
      } catch (error) {
        const message =
          error instanceof Error ? error.message : 'Unknown bridge error'
        output.write(`\n[bridge error] ${message}\n\n`)
      }
    }
  } finally {
    rl.close()
  }
}

main().catch(error => {
  const message = error instanceof Error ? error.message : 'Unknown error'
  output.write(`Fatal error: ${message}\n`)
  process.exitCode = 1
})
